################################################################
# Patch Surfnet-only DAMM v2 config state for local DBC fork tests
################################################################

variable "patched_damm_config" {
    description = "DAMM v2 FixedBps100 config account patched for the local DBC fork"
    value = "Hv8Lmzmnju6m7kcokVKvwqz7QPmdX9XfKjJsXz8RXcjp"
}

variable "patched_damm_config_data" {
    description = "Full DAMM v2 FixedBps100 config account data with pool_creator_authority patched to 3ZAnioMz2su8u4F18VxmnWoSh5ScbMRRWRk9kzog6HPK"
    value = ""
}

variable "dbc_pool_authority" {
    description = "Local DBC fork pool_authority PDA"
    value = "3ZAnioMz2su8u4F18VxmnWoSh5ScbMRRWRk9kzog6HPK"
}

action "fund_dbc_pool_authority_flash_rent" "std::send_http_request" {
    description = "Surfpool-only setup: fund DBC pool_authority with 1 SOL for migration flash rent"
    url = input.rpc_api_url
    method = "POST"
    headers = {
        "Content-Type" = "application/json"
    }
    body = {
        "jsonrpc" = "2.0",
        "id" = 1,
        "method" = "surfnet_setAccount",
        "params" = [
            variable.dbc_pool_authority,
            {
                "data" = "",
                "executable" = false,
                "lamports" = 1000000000,
                "owner" = "11111111111111111111111111111111"
            }
        ]
    }
}

action "patch_damm_v2_config_for_local_dbc_fork" "std::send_http_request" {
    description = "Surfpool-only patch: overwrite DAMM v2 FixedBps100 config pool_creator_authority for local fork migration tests"
    url = input.rpc_api_url
    method = "POST"
    headers = {
        "Content-Type" = "application/json"
    }
    body = {
        "jsonrpc" = "2.0",
        "id" = 1,
        "method" = "surfnet_setAccount",
        "params" = [
            variable.patched_damm_config,
            {
                "data" = variable.patched_damm_config_data,
                "executable" = false,
                "lamports" = 3173760,
                "owner" = "cpamdpZCGKUy5JxQXB4dcpGPiikHawvSWAd6mEn1sGG"
            }
        ]
    }
}

output "patched_damm_config" {
    description = "Surfpool-only patched DAMM v2 FixedBps100 config account"
    value = variable.patched_damm_config
}

output "patch_damm_v2_config_response" {
    description = "Raw surfnet_setAccount response"
    value = action.patch_damm_v2_config_for_local_dbc_fork.response_body
}

output "fund_dbc_pool_authority_response" {
    description = "Raw surfnet_setAccount response for pool_authority flash-rent funding"
    value = action.fund_dbc_pool_authority_flash_rent.response_body
}
