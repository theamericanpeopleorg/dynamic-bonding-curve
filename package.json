{
  "type": "module",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "build-local": "anchor build -p dynamic_bonding_curve --ignore-keys -- --features local",
    "build-local-test": "bun run build-local && bunx ts-mocha --runInBand -p ./tsconfig.json -t 1000000 tests/*.tests.ts",
    "build-local-ctest": "bun run build-local && bunx ts-mocha --runInBand -p ./tsconfig.json -t 1000000 tests/backwards_compatibility/*.tests.ts",
    "ixdata": "bunx tsx --tsconfig ./tsconfig.json ./scripts/generate_ix_data_for_tests.ts"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.0",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0"
  },
  "devDependencies": {
    "@anchor-lang/borsh": "^1.0.0",
    "@solana/spl-token": "^0.4.8",
    "@solana/spl-token-metadata": "^0.1.6",
    "@solana/web3.js": "^1.98.2",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "decimal.js": "^10.4.2",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "litesvm": "^0.1.0"
  }
}
